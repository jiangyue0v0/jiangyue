<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>我的个人网站</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: #faf9f8;
            color: #1e1e1e;
            line-height: 1.5;
            scroll-behavior: smooth;
        }

        /* 导航栏 */
        nav {
            position: sticky;
            top: 0;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid #e9e9e7;
            padding: 1rem 2rem;
            z-index: 100;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: center;
            gap: 2.5rem;
            flex-wrap: wrap;
        }

        .nav-container a {
            text-decoration: none;
            color: #2c2c2c;
            font-weight: 500;
            font-size: 1rem;
            transition: color 0.2s;
        }

        .nav-container a:hover {
            color: #8b5a2b;
        }

        /* 公共容器 */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 4rem 2rem;
        }

        /* 主页左右分栏 */
        .hero {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 3rem;
        }

        .hero-left {
            flex: 1;
            min-width: 240px;
        }

        .hero-left h1 {
            font-size: 2.8rem;
            font-weight: 600;
            letter-spacing: -0.01em;
            margin-bottom: 0.75rem;
        }

        .hero-left .tagline {
            font-size: 1.2rem;
            color: #5a5a5a;
            margin-bottom: 1.5rem;
            border-left: 3px solid #c5a059;
            padding-left: 1rem;
        }

        .hero-left .intro-text {
            margin: 1.2rem 0;
            color: #3a3a3a;
        }

        .hero-right {
            flex: 1;
            min-width: 240px;
            display: flex;
            justify-content: center;
        }

        /* 数字形象占位区 — 你可以替换成真实照片 */
        .avatar-frame {
            width: 100%;
            max-width: 320px;
            background: #eae7e0;
            border-radius: 32px;
            aspect-ratio: 1 / 1;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 12px 24px -12px rgba(0, 0, 0, 0.15);
            background-image: url('https://placehold.co/600x600/eae7e0/8b5a2b?text=数字形象');
            background-size: cover;
            background-position: center;
        }

        /* 生平时间线 */
        .timeline {
            margin-top: 2rem;
            position: relative;
            padding-left: 2rem;
            border-left: 3px solid #dcd7cc;
        }

        .timeline-item {
            margin-bottom: 2.5rem;
            position: relative;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2.45rem;
            top: 0.2rem;
            width: 1rem;
            height: 1rem;
            background: #c5a059;
            border-radius: 50%;
            border: 2px solid #faf9f8;
        }

        .timeline-year {
            font-weight: 600;
            font-size: 1.2rem;
            color: #8b5a2b;
            margin-bottom: 0.5rem;
        }

        /* 作品页 — 相册叠加风格 (纵向卡片) */
        .works-grid {
            display: flex;
            flex-direction: column;
            gap: 3rem;
        }

        .work-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 6px 14px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .work-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 28px -12px rgba(0, 0, 0, 0.12);
        }

        .work-media {
            width: 100%;
            background: #f0ede8;
            min-height: 240px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            color: #6b5a44;
        }

        /* 图片/视频占位样式 — 你替换成真实内容 */
        .placeholder-img {
            width: 100%;
            background: #e2dbcf;
            padding: 3rem;
            text-align: center;
        }

        .work-description {
            padding: 1.5rem;
            border-top: 1px solid #f0ede8;
        }

        .work-description p {
            margin-bottom: 0.25rem;
        }

        .work-title {
            font-weight: 600;
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
        }

        /* 分栏区分照片 / 视